@model ServiceRequest
@{
    ViewData["Title"] = "Submit Request";
}

<h1>Submit Service Request</h1>

<form asp-action="Create" method="post" class="form-card">
    <div asp-validation-summary="ModelOnly" class="validation"></div>

    <label asp-for="Title"></label>
    <input asp-for="Title" />
    <span asp-validation-for="Title" class="validation"></span>

    <label asp-for="Category"></label>
    <select asp-for="Category">
        <option>IT Support</option>
        <option>Maintenance</option>
        <option>Cleaning</option>
        <option>Room Issue</option>
        <option>Equipment Request</option>
        <option>Other</option>
    </select>

    <label asp-for="Priority"></label>
    <select asp-for="Priority">
        <option>Low</option>
        <option selected>Medium</option>
        <option>High</option>
        <option>Critical</option>
    </select>

    <label asp-for="Location"></label>
    <input asp-for="Location" />

    <label asp-for="Description"></label>
    <textarea asp-for="Description" rows="6"></textarea>
    <span asp-validation-for="Description" class="validation"></span>

    <button type="submit">Submit Request</button>
</form>
